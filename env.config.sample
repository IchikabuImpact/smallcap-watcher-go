# Copy to env.config and edit for your environment.
# VPS default path: /var/www/jpx-smallcap-watcher
DB_HOST=localhost:3306
DB_USER=jpx_user
DB_PASSWORD=jpx_password
DB_NAME=jpx_data

# Base URL for the scraper API (no trailing slash needed).
# Node.js runs on the host, so localhost is normally correct on the VPS.
SCRAPER_BASE_URL=http://localhost:8085
# Request interval between scraper API calls (e.g., 3s, 500ms, 1m)
SCRAPER_REQUEST_INTERVAL=3s

# Apache should publish this directory as the static document root or alias.
OUTPUT_DIR=public
# Guard threshold for index freshness. If index is older than this after --gen, process exits non-zero.
INDEX_MAX_AGE=36h
